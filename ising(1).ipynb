   "source": [
    "'''\n",
    "Repeat for a 40x40 lattice\n",
    "'''\n",
    "import numpy as np\n",
    "from math import exp\n",
    "import random\n",
    "\n",
    "# parameters\n",
    "size = 40\n",
    "\n",
    "# spin array\n",
    "s = np.zeros((size, size), dtype=int)\n",
    "\n",
    "# track steps\n",
    "step = 0\n",
    "total_steps = 100 * size * size\n",
    "\n",
    "\n",
    "def print_grid(label):\n",
    "    print(f\"\\n{label}\")\n",
    "    for row in s:\n",
    "        print(\"\".join(\"猬淺" if x == 1 else \"猬沑" for x in row))\n",
    "\n",
    "\n",
    "def initialize():\n",
    "    for i in range(size):\n",
    "        for j in range(size):\n",
    "            s[i, j] = 1 if random.random() < 0.5 else -1\n",
    "\n",
    "    # print ONLY the initial grid\n",
    "    #print_grid(\"Initial grid:\")\n",
    "\n",
    "\n",
    "def deltaU(i, j):\n",
    "    top = s[(i - 1) % size, j]\n",
    "    bottom = s[(i + 1) % size, j]\n",
    "    left = s[i, (j - 1) % size]\n",
    "    right = s[i, (j + 1) % size]\n",
    "    return 2 * s[i, j] * (top + bottom + left + right)\n",
    "\n",
    "\n",
    "def main():\n",
    "\n",
    "    # set temperatures\n",
    "    temperatures = [10, 5, 4, 3, 2.5]\n",
    "    \n",
    "    for T in temperatures:\n",
    "        global step\n",
    "    \n",
    "        initialize()\n",
    "    \n",
    "        for step in range(total_steps):\n",
    "            i = random.randrange(size)\n",
    "            j = random.randrange(size)\n",
    "    \n",
    "            Ediff = deltaU(i, j)\n",
    "    \n",
    "            if Ediff <= 0 or random.random() < exp(-Ediff / T):\n",
    "                s[i, j] *= -1\n",
    "    \n",
    "        # print ONLY the final grid\n",
    "        print_grid(f\"T = {T}:\")\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    main()\n"
   ]
  },
